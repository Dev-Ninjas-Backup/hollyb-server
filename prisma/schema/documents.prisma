model Document {
  id               String       @id @default(uuid()) @db.Uuid
  user_id          String       @db.Uuid
  type             DocumentType
  file_url         String
  status           ReviewStatus
  rejection_reason String?
  uploaded_at      DateTime     @default(now())
  reviewed_at      DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("documents")
}
