model Conversation {
  id         String   @id @default(uuid()) @db.Uuid
  job_id     String?  @db.Uuid
  title      String?
  created_at DateTime @default(now())

  job                  Job?                  @relation(fields: [job_id], references: [id], onDelete: SetNull)
  conversation_members ConversationMember[]
  messages             Message[]

  @@map("conversations")
}
