model Earning {
  id           String    @id @default(uuid()) @db.Uuid
  shift_id     String    @db.Uuid
  employee_id  String    @db.Uuid
  gross_amount Decimal?  @db.Decimal(12, 2)
  platform_fee Decimal?  @db.Decimal(12, 2)
  net_amount   Decimal?  @db.Decimal(12, 2)
  is_paid      Boolean   @default(false)
  paid_at      DateTime?
  created_at   DateTime  @default(now())

  employee EmployeeProfile @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@map("earnings")
}
