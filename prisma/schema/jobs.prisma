model Job {
  id           String         @id @default(uuid()) @db.Uuid
  employer_id  String         @db.Uuid
  title        String
  category     String?
  description  String?
  job_type     JobType
  is_urgent    Boolean        @default(false)
  start_date   DateTime?      @db.Date
  end_date     DateTime?      @db.Date
  start_time   DateTime?      @db.Time(6)
  end_time     DateTime?      @db.Time(6)
  payment_type JobPaymentType
  amount       Decimal?       @db.Decimal(12, 2)
  location     String?
  latitude     Float?
  longitude    Float?
  status       JobStatus
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  employer         EmployerProfile @relation(fields: [employer_id], references: [id], onDelete: Cascade)
  job_skills       JobSkill[]
  job_applications JobApplication[]
  job_assignments  JobAssignment[]
  shifts           Shift[]
  payments         Payment[]
  reviews          Review[]

  @@map("jobs")
}
