{
  "name": "hollyb-server",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prisma:generate:clean": "node -e \"require('fs').rmSync('prisma/generated',{ recursive: true, force: true })\" && npx prisma generate",
    "build": "npm run prisma:generate:clean && npx nest build",
    "format": "prettier --ignore-path .gitignore --check \"**/*.+(js|ts|json)\"",
    "format:fix": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts,.js,.jsx,.tsx --fix",
    "start": "npm run prisma:generate:clean && npx prisma migrate deploy && npm run prisma:seed && npm run format:fix && npm run ci:fix && node dist/main",
    "dev": "npm run prisma:generate:clean && npx prisma migrate deploy && npm run prisma:seed && npx nest start --watch",
    "start:prod": "node dist/main",
    "start:docker": "npx prisma migrate deploy && npm run prisma:seed && node dist/src/main.js",
    "prisma:validate": "npx prisma validate",
    "prisma:format": "npx prisma format",
    "prisma:generate": "npm run prisma:generate:clean",
    "prisma:push": "npx prisma db push",
    "prisma:migrate": "npx prisma migrate deploy",
    "prisma:reset": "npx prisma migrate reset",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "npx prisma studio",
    "ci:check": "npm run format && npm run lint && npm run db:validate && npm run build && npm run start",
    "ci:fix": "npm run format:fix",
    "deploy:check": "docker compose --profile prod build --no-cache",
    "test": "jest --config ./test/jest-e2e.json",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "dbup": "npx prisma migrate dev && npm run prisma:generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.1.14",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@types/stripe": "^8.0.416",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "dotenv": "^17.3.1",
    "firebase-admin": "^13.6.1",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "stripe": "^20.3.1",
    "tsx": "^4.20.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.11",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "@types/socket.io": "^3.0.2",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.4.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
